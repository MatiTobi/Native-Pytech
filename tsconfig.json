{
	"compilerOptions": {
		"jsx": "react-native",
		"esModuleInterop": true,
		"outDir": "./dist",
		"declaration": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "esnext",
		"skipLibCheck": true,
		"baseUrl": ".",
		"rootDir": ".",
		"paths": {
			"@/*": [
				"./src/*"
			],
		}
	},
	"include": [
		"declarations.d.ts",
		"src/**/*"
	],
	"exclude": [
		"node_modules",
		"dist"
	],
}
