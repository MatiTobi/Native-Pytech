{
    "compilerOptions": {
        "baseUrl": ".",
        "jsx": "react-native",
        "esModuleInterop": true,
        "outDir": "./dist",
        "declaration": true,
        "module": "commonjs",
        "target": "esnext",
        "skipLibCheck": true,
    },
    "include": [
        "declarations.d.ts",
        "index.ts",
        "constants/**/*",
        "components/**/*",
        "table/**/*",
        "providers/**/*",
        "assets/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}