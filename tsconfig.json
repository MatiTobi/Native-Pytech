{
    "compilerOptions": {
        "baseUrl": ".",
        "jsx": "react-native",
        "esModuleInterop": true,
        "outDir": "./dist",
        "declaration": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "esnext",
        "skipLibCheck": true,
    },
    "include": [
        "declarations.d.ts",
        "src/index.ts",
        "src/constants/**/*",
        "src/components/**/*",
        "src/table/**/*",
        "src/providers/**/*",
        "src/assets/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}