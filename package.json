{
    "name": "native-pytech",
    "version": "1.0.0",
    "description": "Libreria de React Native Pytech",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "author": "Matias Tobias Gutierrez",
    "license": "MIT",
    "scripts": {
        "build": "tsc && tsc-alias && copyfiles -u 1 \"src/assets/images/**/*\" dist/",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "@expo/vector-icons": "^15.0.3",
        "@legendapp/list": "^2.0.19",
        "@legendapp/state": "^3.0.0-beta.45",
        "@react-native-masked-view/masked-view": "0.3.2",
        "color2k": "^2.0.3",
        "expo-blur": "~15.0.8",
        "expo-constants": "~18.0.9",
        "expo-device": "~8.0.10",
        "expo-glass-effect": "~0.1.9",
        "expo-linear-gradient": "~15.0.8",
        "expo-mesh-gradient": "~0.4.8",
        "expo-router": "~6.0.23",
        "react": "^19.2.5",
        "react-native": "0.81.5",
        "react-native-reanimated": "~4.1.1",
        "react-native-reorderable-list": "^0.17.0",
        "react-native-svg": "^15.12.1",
        "react-native-worklets": "0.5.1"
    },
    "devDependencies": {
        "@types/react": "~19.1.10",
        "babel-plugin-module-resolver": "^5.0.3",
        "copyfiles": "^2.4.1",
        "expo": "~54.0.33",
        "react": "19.2.5",
        "react-native": "0.81.5",
        "tsc-alias": "^1.8.16",
        "typescript": "~5.9.2"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./constants/*": {
            "types": "./dist/constants/*.d.ts",
            "default": "./dist/constants/*.js"
        },
        "./table": {
            "types": "./dist/table/index.d.ts",
            "default": "./dist/table/index.js"
        },
        "./page": {
            "types": "./dist/page/index.d.ts",
            "default": "./dist/page/index.js"
        },
        "./components": {
            "types": "./dist/components/index.d.ts",
            "default": "./dist/components/index.js"
        },
        "./providers/*": {
            "types": "./dist/providers/*.d.ts",
            "default": "./dist/providers/*.js"
        },
        "./assets": {
            "types": "./dist/assets/index.d.ts",
            "default": "./dist/assets/index.js"
        },
        "./assets/components/*": {
            "types": "./dist/assets/components/*.d.ts",
            "default": "./dist/assets/components/*.js"
        },
        "./assets/ionicons/*": {
            "types": "./dist/assets/ionicons/*.d.ts",
            "default": "./dist/assets/ionicons/*.js"
        },
        "./assets/images/*": {
            "default": "./dist/assets/images/*"
        }
    }
}
